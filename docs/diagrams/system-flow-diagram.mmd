flowchart TB
    user[User]
    website[Website Login Page]
    desktop[OnPass Desktop App<br/>Local API]
    storage[(chrome.storage.local)]

    subgraph extension[OnPass Extension]
        direction TB

        subgraph popup[Popup Layer]
            direction TB
            popupUi[popup.html / popup.js]
            popupApi[popup-api.js]
            popupStorage[popup-storage.js]
        end

        subgraph content[Content Script Layer]
            direction TB
            autofillCore[autofill-core.js]
            autofillEngine[autofill-engine.js]
            detection[autofill-detection.js]
            fill[autofill-fill.js]
        end

        subgraph background[Background Service Worker]
            direction TB
            bgIndex[index.js]
            listeners[listeners.js]
            token[token.js]
            passwordsApi[passwords-api.js]
            cache[cache.js]
            domainMatch[domain-match.js]
        end

        shared[shared/*.js]
    end

    user -->|Opens browser action popup| popupUi
    popupUi --> popupApi
    popupUi --> popupStorage
    popupStorage <--> |Save / load token| storage
    popupApi --> shared
    popupApi -->|GET /validate| desktop
    popupApi -->|GET /passwords| desktop

    user -->|Focuses login field| website
    website --> autofillCore
    autofillCore --> autofillEngine
    autofillEngine --> detection
    autofillEngine --> fill

    fill -->|GET_SAVED_PASSWORDS| listeners
    bgIndex --> listeners
    listeners --> token
    listeners --> passwordsApi
    listeners --> domainMatch
    token <--> |Read / clear token| storage
    passwordsApi --> cache
    passwordsApi --> shared
    passwordsApi -->|GET /validate| desktop
    passwordsApi -->|GET /passwords| desktop
    listeners -->|Domain-filtered credentials| fill
    fill -->|Inline popup + native setter autofill| website
